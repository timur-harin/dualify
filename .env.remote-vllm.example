# Remote vLLM (OpenAI-compatible server) — copy to `.env`
#
# Base URL = scheme + host + port only (no path, no /v1).
# Same routes as OpenAI: GET /v1/models , POST /v1/chat/completions , POST /v1/completions
# Replace HOST:PORT with your reachable address (VPN / internal IP).
#
# Example (placeholder — use your real host):
DUALIFY_PROVIDER=openai
DUALIFY_BASE_URL=http://HOST:8800
DUALIFY_MODEL=Qwen/Qwen3-Coder-Next-FP8
# If the server uses Bearer auth:
DUALIFY_API_KEY=
