# Copy one preset to `.env` and fill secrets. Never commit `.env`.
#
# Presets (safe to commit):
#   .env.local-ollama.example   — local Ollama (http://127.0.0.1:11434)
#   .env.remote-vllm.example   — self-hosted vLLM / OpenAI-compatible (http://IP:PORT)
#   .env.remote-api.example    — Groq, OpenRouter, etc. (https://…)
#
#   cp .env.local-ollama.example .env
#   cp .env.remote-vllm.example .env
#   cp .env.remote-api.example .env
#
# Core variables (CLI defaults when flags omitted; see dualify.runner):
#   DUALIFY_PROVIDER     ollama | openai
#   DUALIFY_BASE_URL     origin only — NO trailing /v1
#                        Dualify calls: /v1/models (health), /v1/chat/completions (preferred),
#                        /v1/completions (fallback for OpenAI-compatible providers).
#   DUALIFY_MODEL        model id for that provider
#   DUALIFY_API_KEY      required if provider=openai (or use GROQ_API_KEY)
#
# Optional:
#   DUALIFY_OPENAI_USE_CHAT=1   default on; set 0 to prefer completions only
#   DUALIFY_DEBUG_LLM_RAW=1     log raw model text snippet (debug)
