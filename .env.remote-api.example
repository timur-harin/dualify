# Hosted OpenAI-compatible APIs (Groq, OpenRouter, …) — copy to `.env`
#
# Groq (recommended default model for Dualify extraction runs):
#   Docs: https://console.groq.com/keys — list models: GET https://api.groq.com/openai/v1/models
DUALIFY_PROVIDER=openai
DUALIFY_BASE_URL=https://api.groq.com/openai
DUALIFY_MODEL=llama-3.3-70b-versatile
DUALIFY_API_KEY=
# Alternative env name (same value):
# GROQ_API_KEY=

# OpenRouter (base = origin without duplicate /v1):
# DUALIFY_BASE_URL=https://openrouter.ai/api
# DUALIFY_MODEL=meta-llama/llama-3.3-70b-instruct
# DUALIFY_API_KEY=sk-or-v1-...
